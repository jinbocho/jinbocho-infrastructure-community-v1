# Grafana Alloy — environment template (ADR-012, observability profile)
# Copy to alloy.env and fill in your values:
#
#   cp envs/alloy.env.example envs/alloy.env
#
# envs/alloy.env is gitignored and never committed.
#
# Only needed if you run the "observability" Compose profile:
#   docker compose -f docker-compose.community.yml --profile observability up -d
#
# In Grafana Cloud: My Account > (your stack) > Connections > Add new
# connection > OpenTelemetry (OTLP). That page gives you all three values
# below in one place.
GRAFANA_CLOUD_OTLP_ENDPOINT=https://otlp-gateway-prod-eu-west-2.grafana.net/otlp
GRAFANA_CLOUD_OTLP_INSTANCE_ID=YOUR_INSTANCE_ID_HERE
GRAFANA_CLOUD_OTLP_API_TOKEN=YOUR_API_TOKEN_HERE

# Then, per service, set in envs/<service>.env (see each service's
# .env.example for the same two variables):
#   OTEL_ENABLED=true
#   OTEL_EXPORTER_OTLP_ENDPOINT=http://alloy:4318
