# Auth Service — environment template
# Copy to auth-service.env and fill in your values:
#
#   cp envs/auth-service.env.example envs/auth-service.env
#
# envs/auth-service.env is gitignored and never committed.

# Set to false in production.
DEBUG=true

# Local dev DB (Docker Compose): user=postgres, password=POSTGRES_PASSWORD from .env, host=container name.
# Production (Neon): postgresql+asyncpg://user:pass@ep-xxx.neon.tech/auth_db?ssl=require
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_POSTGRES_PASSWORD@jinbocho-postgres-auth:5432/auth_db

# Shared JWT secret — MUST be identical across api-gateway, auth-service, and catalog-service.
# Generate a strong random value with: openssl rand -hex 32
JWT_SECRET_KEY=YOUR_JWT_SECRET_KEY_HERE

# Must match catalog-service's INTERNAL_SERVICE_TOKEN exactly — authenticates
# catalog -> auth internal calls (e.g. loan reminder emails).
# Generate a strong random value with: openssl rand -hex 32
INTERNAL_SERVICE_TOKEN=YOUR_INTERNAL_SERVICE_TOKEN_HERE

ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Must match api-gateway's/catalog-service's JINBOCHO_FEATURES. Community
# edition: catalog,auth. Pro edition (adds "ai"): catalog,auth,ai — required
# to enable Kids Mode on a library, a Pro-tier feature.
JINBOCHO_FEATURES=catalog,auth

# Public URL of the frontend — used to build the links in invite/reset-password emails.
# The setup-vps-*.sh scripts set this automatically; defaults to localhost for local dev.
FRONTEND_BASE_URL=http://localhost:5173

# SMTP — leave SMTP_HOST empty to fall back to printing the link in the service logs.
# setup-vps-*.sh only asks for SMTP_USER/SMTP_PASSWORD/EMAIL_FROM and fills host+port
# in automatically (Gmail). For a different provider, set these by hand.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=YOUR_GMAIL_ADDRESS_HERE
SMTP_PASSWORD=YOUR_GMAIL_APP_PASSWORD_HERE
EMAIL_FROM=YOUR_GMAIL_ADDRESS_HERE
