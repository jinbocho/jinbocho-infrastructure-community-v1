# Catalog Service — environment template
# Copy to catalog-service.env and fill in your values:
#
#   cp envs/catalog-service.env.example envs/catalog-service.env
#
# envs/catalog-service.env is gitignored and never committed.

# Set to false in production.
DEBUG=true

# Local dev DB (Docker Compose): user=postgres, password=POSTGRES_PASSWORD from .env, host=container name.
# Production (Neon): postgresql+asyncpg://user:pass@ep-xxx.neon.tech/catalog_db?ssl=require
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_POSTGRES_PASSWORD@jinbocho-postgres-catalog:5432/catalog_db

# Internal Docker network address of auth service.
AUTH_SERVICE_URL=http://jinbocho-auth:8001

# Must match auth-service's INTERNAL_SERVICE_TOKEN exactly — authenticates
# catalog -> auth internal calls (e.g. loan reminder emails).
# Generate a strong random value with: openssl rand -hex 32
INTERNAL_SERVICE_TOKEN=YOUR_INTERNAL_SERVICE_TOKEN_HERE

# How many days before a loan's due_date the reminder email job fires.
LOAN_REMINDER_LEAD_DAYS=1

# Must match api-gateway's JINBOCHO_FEATURES. Available values: catalog,
# auth, ai, kids. Community edition: catalog,auth. "ai" and "kids" are
# independent optional modules — Pro edition ships both by default.
JINBOCHO_FEATURES=catalog,auth

# Must match auth-service's JWT_SECRET_KEY so the catalog can validate tokens it issued.
# Generate a strong random value with: openssl rand -hex 32
JWT_SECRET_KEY=YOUR_JWT_SECRET_KEY_HERE
JWT_ALGORITHM=HS256

# Google Books API key — get one free at https://console.cloud.google.com/
# APIs & Services > Credentials > Create API Key > restrict to Books API
# Without this key the shared quota (1000 req/day) is exhausted quickly.
GOOGLE_BOOKS_API_KEY=YOUR_GOOGLE_BOOKS_API_KEY_HERE
