# API Gateway — environment template
# Copy to api-gateway.env and fill in your values:
#
#   cp envs/api-gateway.env.example envs/api-gateway.env
#
# envs/api-gateway.env is gitignored and never committed.

# Set to false in production.
DEBUG=true

# Shared JWT secret — MUST be identical across api-gateway, auth-service, and catalog-service.
# Generate a strong random value with: openssl rand -hex 32
JWT_SECRET_KEY=YOUR_JWT_SECRET_KEY_HERE
# Must match the values set in auth-service (jwt_issuer / jwt_audience in its config).
JWT_ISSUER=jinbocho-auth
JWT_AUDIENCE=jinbocho

# Internal Docker network addresses — do not change for local dev.
AUTH_SERVICE_URL=http://auth-service:8001
CATALOG_SERVICE_URL=http://catalog-service:8002

# Allowed origins for CORS. Use ["*"] for local dev.
# In production set to your frontend URL: ["https://your-fe.onrender.com"]
CORS_ORIGINS=["*"]
# Feature flags — comma-separated list of enabled modules.
# Available values: catalog, auth, ai, kids. Community edition: catalog,auth.
# "ai" and "kids" are independent optional modules — Pro edition ships both
# by default.
JINBOCHO_FEATURES=catalog,auth
