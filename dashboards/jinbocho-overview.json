        "spec": {
          "id": 12,
          "title": "Recent container logs (jinbocho-*) — adjust the label if empty",
          "description": "Alloy's discovery.relabel in config.alloy only KEEPS targets matching /jinbocho-(auth|catalog|api-gateway|ai) — it never renames __meta_docker_container_name to a plain label, so the exact Loki label Alloy's loki.source.docker actually exports wasn't confirmed by code inspection. Open Explore > your Loki datasource > Label browser, find the right label (commonly \"container\" or similar) and edit this panel's query to match — this is a best-effort starting query.",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "loki",
                      "version": "v0",
                      "datasource": {
                        "name": "grafanacloud-logs"
