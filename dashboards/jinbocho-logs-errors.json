{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus (Grafana Cloud Mimir)",
      "description": "The grafanacloud-<stack>-prom datasource in your Grafana Cloud stack",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    },
    {
      "name": "DS_LOKI",
      "label": "Loki (Grafana Cloud logs)",
      "description": "The grafanacloud-<stack>-logs datasource in your Grafana Cloud stack",
      "type": "datasource",
      "pluginId": "loki",
      "pluginName": "Loki"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "datasource", "id": "loki", "name": "Loki", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "logs", "name": "Logs", "version": "" }
  ],
  "title": "Jinbocho — Logs & Errors",
  "description": "Error triage view across all 4 services. ERROR-level detection relies on the documented log line format (see CLAUDE.md: '%Y-%m-%d %H:%M:%S LEVEL [logger.name] message') via a text regex, NOT a Loki label, since the exact stream-selector label Alloy assigns to jinbocho-* containers was not confirmed from config.alloy (it only keeps matching targets, never renames a label) — verify/adjust the stream selector via the Loki label browser in Explore if panels show no data.",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "timezone": "browser",
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "1m",
  "tags": ["jinbocho", "adr-012", "logs"],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "label": "Prometheus"
      },
      {
        "name": "DS_LOKI",
        "type": "datasource",
        "query": "loki",
        "current": {},
        "hide": 0,
        "label": "Loki"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Error rate (metrics — cross-reference with logs below)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "5xx error rate by service",
      "description": "100 * sum(rate(http_requests_total{status=\"5xx\"}[5m])) by (service_name) / sum(rate(http_requests_total[5m])) by (service_name)",
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "100 * sum(rate(http_requests_total{status=\"5xx\"}[5m])) by (service_name) / sum(rate(http_requests_total[5m])) by (service_name)",
          "legendFormat": "{{service_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 5 }] }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 3,
      "type": "row",
      "title": "Log volume",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 8 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Total log lines per minute (all jinbocho-* containers)",
      "description": "sum(count_over_time({container=~\"jinbocho-.+\"}[1m])) — adjust the label name (container) if your Loki label browser shows a different one.",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 9 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(count_over_time({container=~\"jinbocho-.+\"}[1m]))",
          "legendFormat": "log lines/min",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 30 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "ERROR-level log lines per minute",
      "description": "sum(count_over_time({container=~\"jinbocho-.+\"} |~ \" ERROR \" [1m])) — matches the documented log format '%Y-%m-%d %H:%M:%S LEVEL [logger.name] message' from CLAUDE.md.",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 9 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(count_over_time({container=~\"jinbocho-.+\"} |~ \" ERROR \" [1m]))",
          "legendFormat": "ERROR lines/min",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "fillOpacity": 30 },
          "color": { "mode": "fixed", "fixedColor": "red" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 6,
      "type": "row",
      "title": "Error log browser",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 7,
      "type": "logs",
      "title": "Recent ERROR / Exception lines (all services)",
      "description": "{container=~\"jinbocho-.+\"} |~ \" ERROR |Traceback|Exception\"",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 17 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "{container=~\"jinbocho-.+\"} |~ \" ERROR |Traceback|Exception\"",
          "refId": "A"
        }
      ],
      "options": { "showTime": true, "wrapLogMessage": true, "sortOrder": "Descending", "enableLogDetails": true }
    },
    {
      "id": 8,
      "type": "row",
      "title": "Full log browser",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 9,
      "type": "logs",
      "title": "All logs (jinbocho-*)",
      "description": "{container=~\"jinbocho-.+\"} — unfiltered, for manual investigation.",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 28 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "{container=~\"jinbocho-.+\"}",
          "refId": "A"
        }
      ],
      "options": { "showTime": true, "wrapLogMessage": true, "sortOrder": "Descending", "enableLogDetails": true }
    }
  ]
}
