{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus (Grafana Cloud Mimir)",
      "description": "The grafanacloud-<stack>-prom datasource in your Grafana Cloud stack",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    },
    {
      "name": "DS_LOKI",
      "label": "Loki (Grafana Cloud logs)",
      "description": "The grafanacloud-<stack>-logs datasource in your Grafana Cloud stack",
      "type": "datasource",
      "pluginId": "loki",
      "pluginName": "Loki"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "datasource", "id": "loki", "name": "Loki", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "logs", "name": "Logs", "version": "" }
  ],
  "title": "Jinbocho — Logs & Errors",
  "description": "Error triage view across all 4 services, filterable by the $service_name variable. Log streams are selected by the service_name label — config.alloy's discovery.relabel sets loki.resource.service.name per container (auth-service/catalog-service/api-gateway/ai-service), promoted by otelcol.receiver.loki to the OTel service.name resource attribute, which Grafana Cloud indexes as service_name (same label used by the Prometheus metrics panels, so metrics and logs correlate). ERROR-level detection still relies on a text regex over the documented log line format (CLAUDE.md: '%Y-%m-%d %H:%M:%S LEVEL [logger.name] message'), not a Loki label, since level isn't parsed out as a structured field.",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "timezone": "browser",
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "1m",
  "tags": ["jinbocho", "adr-012", "logs"],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "label": "Prometheus"
      },
      {
        "name": "DS_LOKI",
        "type": "datasource",
        "query": "loki",
        "current": {},
        "hide": 0,
        "label": "Loki"
      },
      {
        "name": "service_name",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": { "query": "label_values(up, service_name)", "refId": "service_name" },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": ["$__all"] },
        "label": "Service",
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Error rate (metrics — cross-reference with logs below)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "5xx error rate by service",
      "description": "100 * sum(rate(http_requests_total{service_name=~\"$service_name\", status=\"5xx\"}[5m])) by (service_name) / sum(rate(http_requests_total{service_name=~\"$service_name\"}[5m])) by (service_name)",
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "100 * sum(rate(http_requests_total{service_name=~\"$service_name\", status=\"5xx\"}[5m])) by (service_name) / sum(rate(http_requests_total{service_name=~\"$service_name\"}[5m])) by (service_name)",
          "legendFormat": "{{service_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 5 }] }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 3,
      "type": "row",
      "title": "Log volume",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 8 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Log lines per minute by service",
      "description": "sum(count_over_time({service_name=~\"$service_name\"}[1m])) by (service_name)",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 9 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(count_over_time({service_name=~\"$service_name\"}[1m])) by (service_name)",
          "legendFormat": "{{service_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 30 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "ERROR-level log lines per minute by service",
      "description": "sum(count_over_time({service_name=~\"$service_name\"} |~ \" ERROR \" [1m])) by (service_name) — matches the documented log format '%Y-%m-%d %H:%M:%S LEVEL [logger.name] message' from CLAUDE.md.",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 9 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(count_over_time({service_name=~\"$service_name\"} |~ \" ERROR \" [1m])) by (service_name)",
          "legendFormat": "{{service_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "fillOpacity": 30 },
          "color": { "mode": "fixed", "fixedColor": "red" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 6,
      "type": "row",
      "title": "Error log browser",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 7,
      "type": "logs",
      "title": "Recent ERROR / Exception lines",
      "description": "{service_name=~\"$service_name\"} |~ \" ERROR |Traceback|Exception\"",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 17 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "{service_name=~\"$service_name\"} |~ \" ERROR |Traceback|Exception\"",
          "refId": "A"
        }
      ],
      "options": { "showTime": true, "wrapLogMessage": true, "sortOrder": "Descending", "enableLogDetails": true }
    },
    {
      "id": 8,
      "type": "row",
      "title": "Full log browser",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 9,
      "type": "logs",
      "title": "All logs",
      "description": "{service_name=~\"$service_name\"} — unfiltered, for manual investigation.",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 28 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "{service_name=~\"$service_name\"}",
          "refId": "A"
        }
      ],
      "options": { "showTime": true, "wrapLogMessage": true, "sortOrder": "Descending", "enableLogDetails": true }
    }
  ]
}
